## Message Part Rendering

### MessagePartRenderer.tsx

Handles rendering of different message part types:

#### 1. Subagent Indicator

```typescript
const renderSubagentIndicator = (part: MessagePart, index: number) => {
  const meta = SUBAGENT_META[part.type];  // { icon, name }
  const state = part.state || "input-available";
  const isWorking = state === "input-streaming" || state === "input-available";

  return (
    <Agent>
      <AgentHeader name={`${meta.icon} ${meta.name}`} />
      {task && <div>"{task}"</div>}
      <span>
        {isWorking ? "⏳ Working..." : "✅ Completed"}
      </span>
    </Agent>
  );
};
```

**Part Types**:
- `tool-mediaGeneration` → Shows "🎨 Media Agent" card
- `tool-research` → Shows "🔍 Research Agent" card

#### 2. Regular Tools

```typescript
const renderTool = (part: MessagePart, index: number, debugToolUi: boolean) => {
  // Show status (Preparing → Processing → Completed)
  const message = getSimpleToolMessage(part.type, part.state);

  // Show credits deducted (for media tools)
  const showCredits = part.output?.totalCredits !== undefined;

  return (
    <>
      <MessageContent>{message}</MessageContent>
      {showCredits && <MessageContent>Deducted {totalCredits} credits</MessageContent>}
      {part.output && <CustomToolOutput output={part.output} />}
    </>
  );
};
```

**Supported Tools**:
- `tool-generateImage`
- `tool-generateVideo`
- `tool-removeBackground`
- `tool-upscaleImage`
- And all other media tools

#### 3. Message Part Types

```typescript
switch (part.type) {
  case "text":
    return <Response>{part.text}</Response>;

  case "error":
    return <ErrorCard />;

  case "file":
    return <FileAttachment />;

  case "tool-mediaGeneration":
  case "tool-research":
    return renderSubagentIndicator(part, index);

  case "tool-generateImage":
  case "tool-generateVideo":
  // ... other tools
    return renderTool(part, index, debugToolUi);
}
```

