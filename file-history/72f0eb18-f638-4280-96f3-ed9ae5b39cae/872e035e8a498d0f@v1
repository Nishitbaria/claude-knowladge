        await createServerEvent(
          "model_generation",
          String(userId ?? ""),
          eventProperties,
        );
      } catch (phErr: any) {
        // PostHog capture failed silently
      }

      // Return immediately with predictionId for client-side polling
      return {
        success: true,
        predictionId,
        status: "succeeded",
        output: {
          predictionId,
          provider: "replicate",
        },
        model_name: "image-upscaler",
        input_image: imageUrl,
        upscale_factor,
        compression_quality,
        credits,
        totalCredits: credits,
      };
    } else {
      // [error] API indicated failure
      logger.error("[error] image upscaler API call failed", result);
      throw new Error(
        result.message || "Failed to create image upscaler generation",
      );
    }
  } catch (error) {
    // [error] Unexpected exception
    logger.error("[error] generateImageUpscalerAction failed", error);

    // Log additional axios error details if available
    if (axios.isAxiosError(error)) return handleAxiosError(error as AxiosError);

    return {
      success: false,
      error: error instanceof Error ? error.message : "Unknown error occurred",
    };
  }
}
